POSTGRES_USER=copy_trade
POSTGRES_PASSWORD=copy_trade
POSTGRES_DB=copy_trade
COPY_TRADE_ENV=local
COPY_TRADE_DATABASE_URL=postgresql+asyncpg://copy_trade:copy_trade@postgres:5432/copy_trade
COPY_TRADE_REDIS_URL=redis://redis:6379/0
COPY_TRADE_NATS_URL=nats://nats:4222
COPY_TRADE_ADMIN_API_TOKEN=change-me-local-admin-token
COPY_TRADE_ALLOW_ENV_ADMIN_TOKEN=true
COPY_TRADE_ADMIN_RATE_LIMIT_REQUESTS=120
COPY_TRADE_ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
